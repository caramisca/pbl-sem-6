{
  "name": "room-manager-bridge",
  "private": true,
  "version": "0.1.0",
  "description": "Serial-to-WebSocket bridge for the Room Manager Mega 2560 firmware",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "demo": "tsx src/index.ts --source demo --device rm-living",
    "serial": "tsx src/index.ts --source serial",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "room-manager": "file:..",
    "serialport": "^12.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/ws": "^8.5.10",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
